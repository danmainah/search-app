<h1>Articles</h1>

<ol>
  <% @articles.each do |article| %>
    <li>
      <h3>
        <%= link_to article.title, controller: "articles", action: "show", id: article.id%>
      </h3>
      <p>
        <%= article.text %>
      </p>
    </li>
  <% end -%>
</ol>
<%= link_to 'New Article', new_article_path %>
